# =================
# CompanyAI Backend Configuration
# =================

# Server Configuration
PORT=5000
NODE_ENV=development

# =================
# AI / OpenWebUI Integration
# =================

# OpenWebUI Server URL (where your OpenWebUI instance is running)
OPENWEBUI_URL=http://localhost:3001

# RAG (Retrieval Augmented Generation) Configuration
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_INDEX_PATH=./backend/rag_index.json

# =================
# Security Configuration (Optional - not yet implemented)
# =================

# JWT Secret for token signing (set in production)
# JWT_SECRET=your-super-secure-jwt-secret-here

# Rate Limiting (requests per window) - using defaults currently
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# =================
# Database Configuration (planned - not yet implemented)
# =================

# Database connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/companyai
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=companyai
# DB_USER=companyai_user
# DB_PASSWORD=your-db-password

# =================
# Email Configuration (planned - not yet implemented)
# =================

# SMTP Configuration for notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@company.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@company.com

# =================
# File Storage Configuration (planned - not yet implemented)
# =================

# File upload configuration
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=10485760
# ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,png

# =================
# Entra ID / Microsoft Graph Integration (AKTIV)
# =================

# Entra Admin Center Reference (for documentation)
ENTRA_ADMIN_CENTER_URL=https://entra.microsoft.com

# Microsoft Graph App Registration (Client Credentials Flow)
# WICHTIG: Diese Werte müssen aus dem Azure Portal / Entra Admin Center kommen
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here  
AZURE_CLIENT_SECRET=your-client-secret-here

# Graph API Configuration
GRAPH_BASE_URL=https://graph.microsoft.com

# Entra Sync Configuration
ENTRA_SYNC_ENABLED=true
ENTRA_SYNC_INTERVAL_MS=3600000

# =================
# External APIs (planned - not yet implemented)
# =================

# Third-party integrations
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# =================
# Development Configuration
# =================

# Enable detailed logging in development
DEBUG=true

# CORS Origins (comma-separated for production) - currently allowing all in development
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# =================
# Performance & Monitoring (planned - not yet implemented)
# =================

# Application monitoring
# APM_SERVICE_NAME=companyai-backend
# APM_SERVER_URL=http://localhost:8200

# Redis configuration for caching
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password

# =================
# Feature Flags (planned - not yet implemented)
# =================

# Enable/disable features
# FEATURE_AI_CHAT=true
# FEATURE_RAG_SEARCH=true
# FEATURE_EMAIL_NOTIFICATIONS=false
# FEATURE_SLACK_INTEGRATION=false
